# Copy this file to .env and fill in your key.
# Leave blank / don't set LLM_PROVIDER to run in mock mode (no API calls).

# Choose provider: groq | openai | (blank = mock mode)
LLM_PROVIDER=groq

# Groq (fast, free tier — recommended)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key_here
